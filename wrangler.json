{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "me",
  "compatibility_date": "2026-05-29",
  "kv_namespaces": [
    {
      "binding": "MARKS_BLUR_CACHE",
      "id": "bda1318b98c8446b96c0ba58f25c4186",
      "remote": true
    }
  ],
  "d1_databases": [
    {
      "binding": "POST_VIEWS_DB",
      "database_name": "post-views",
      "database_id": "0fbc93ff-9a32-43d2-bd9a-83f79ebf4dce",
      "migrations_dir": "migrations"
    }
  ],
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "post_views"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MARKS_BUCKET",
      "bucket_name": "marks",
      "remote": true
    }
  ],
  "images": {
    "binding": "IMAGES",
    "remote": true
  }
}
